# ============================================================================
# TradingAgents-TW Secure Edition v0.3.0 — 環境設定範本
# ============================================================================
#
# 📌 使用方式：
#   1. cp .env.example .env
#   2. 依下方各 Phase 的「需值時機」逐步填入
#   3. 不要把 .env 提交到 git（已在 .gitignore）
#
# 📌 Secret 產生指令（用於 SECRET_KEY / DATA_ENCRYPTION_KEY / DB / Redis 密碼）：
#    python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
#    或更短的隨機字串：
#    python -c "import secrets; print(secrets.token_urlsafe(32))"
# ============================================================================


# ── 應用層 ──────────────────────────────────────────
APP_ENV=dev                                  # dev | test | staging | prod
APP_VERSION=0.3.0
LOG_LEVEL=INFO
LOG_FORMAT=json                              # json | console（dev 可用 console）
ADMIN_EMAIL=admin@example.com                # 系統管理者 + 初始 admin 帳號（用於 SEC EDGAR User-Agent + seed 第一個 admin）
ADMIN_INITIAL_PASSWORD=ChangeMeOnFirstLogin!1234   # 第一次 seed 用，登入後強制改
DEFAULT_TIMEZONE=Asia/Taipei
DEFAULT_LANG=zh-TW


# ── 安全（產生方式見上方註解；P3+ 必填） ────────────────
SECRET_KEY=                                  # ≥ 32 bytes base64 字串，JWT 簽名 + CSRF token
SECRET_KEY_PREVIOUS=                         # 雙 key rotation 用，平時空（換 key 期間 7 天並存）
DATA_ENCRYPTION_KEY=                         # Fernet key（與 SECRET_KEY 必須不同），加密 LINE/Telegram token
CORS_ORIGINS=["http://localhost:3000"]
CSP_PROD_ENABLED=false                       # P18 prod 設 true 啟用 CSP nonce


# ── DB（密碼在 P2 補入隨機 32 字元；P3+ 必填） ──────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tradingagents_tw
POSTGRES_SUPERUSER_PASSWORD=                 # 維運用，僅 init 與 dump
TA_MIGRATION_PASSWORD=                       # alembic 用（CREATEDB 權限）
TA_SERVICE_RW_PASSWORD=                      # 後端業務用（DML only，無 DDL）
TA_AGENT_RO_PASSWORD=                        # Agent / Tool 用（read-only，防 prompt injection）
POOL_SIZE_RW=20
POOL_SIZE_RO=30
STATEMENT_TIMEOUT_MS=30000
LOCK_TIMEOUT_MS=10000


# ── Redis（P2 補入；P3+ 必填） ────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                              # P2 補入
POOL_SIZE_REDIS=50


# ── Qdrant（P2 補入；P4+ 必填） ───────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=                              # P2 補入
EMBEDDING_DIM=768                            # gemini text-embedding-004


# ── 資料源 API key（P5/P6 才需要值） ──────────────────
FINMIND_TOKEN=                               # 強烈建議：https://finmindtrade.com（免費版 600/day）
ALPHA_VANTAGE_API_KEY=                       # 強烈建議：https://www.alphavantage.co/support/#api-key
FINNHUB_API_KEY=                             # 可選：https://finnhub.io（免費 60/min）


# ── LLM Provider（P12+ 才需要值；GOOGLE_API_KEY 必需） ──
GOOGLE_API_KEY=                              # 必需：https://aistudio.google.com/apikey
OPENAI_API_KEY=                              # 可選 fallback：https://platform.openai.com
ANTHROPIC_API_KEY=                           # 可選 fallback：https://console.anthropic.com
LLM_DEFAULT_PROVIDER=google                  # google | openai | anthropic
LLM_DEFAULT_MODEL=gemini-2.0-flash
OPENAI_DEFAULT_MODEL=gpt-4o-mini
ANTHROPIC_DEFAULT_MODEL=claude-haiku-3-5-20241022
GEMINI_EMBEDDING_MODEL=text-embedding-004
LLM_MONTHLY_BUDGET_USD_DEFAULT=50.00         # 用戶預設月預算（每用戶可個別覆寫）


# ── 通知（P18 才需要值；可選） ────────────────────────
LINE_NOTIFY_TOKEN=                           # 可選：https://notify-bot.line.me/my/
TELEGRAM_BOT_TOKEN=                          # 可選：找 @BotFather 申請
TELEGRAM_CHAT_ID=                            # 你的 chat id（用 @userinfobot 取得）


# ============================================================================
# 📅 各 Phase 補值時機提醒
# ============================================================================
# P0/P1：欄位先列齊，值留空或 placeholder（本檔已是這狀態）
# P2  ：DB / Redis / Qdrant 密碼（隨機 32 字元）
# P3  ：SECRET_KEY / DATA_ENCRYPTION_KEY（必需，否則 backend 啟動失敗）
# P5/P6：FINMIND_TOKEN / ALPHA_VANTAGE_API_KEY 等資料源 token
# P12 ：GOOGLE_API_KEY（必需，否則 LangGraph 跑不了）
# P14 ：OPENAI_API_KEY / ANTHROPIC_API_KEY（fallback chain，可選但建議）
# P18 ：LINE_NOTIFY_TOKEN / TELEGRAM_BOT_TOKEN（通知）
# P19 ：另建 .env.prod，不重用 .env（避免 dev/prod 混用）
