# ============================================================================
# TradingAgents Environment Configuration (繁體中文加固版)
# ============================================================================
#
# 設定步驟：
#   1. cp .env.example .env
#   2. chmod 600 .env             # 限制權限為僅自己可讀寫
#   3. 填入您的 API 金鑰
#   4. bash scripts/check_env_security.sh   # 自我檢查
#
# 安全警示：
#   ⚠️  .env 已加入 .gitignore — 切勿手動 commit
#   ⚠️  切勿在公開頻道（截圖/論壇/Issue）貼出完整內容
#   ⚠️  建議為每個 LLM 服務建立獨立、範圍受限的金鑰
#   ⚠️  建議每 90 天輪換一次金鑰
# ============================================================================

# ---------- LLM 提供商（至少設定一個） ----------
# 取得位置：
#   OpenAI       https://platform.openai.com/api-keys
#   Google AI    https://aistudio.google.com/app/apikey
#   Anthropic    https://console.anthropic.com/settings/keys
#   xAI          https://console.x.ai/
#   DeepSeek     https://platform.deepseek.com/api_keys
#   Qwen 通義千問  https://dashscope.console.aliyun.com/
#   GLM 智譜      https://open.bigmodel.cn/
#   OpenRouter   https://openrouter.ai/keys
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=

# ---------- 資料來源 API ----------
# FinnHub (美股財經數據，免費 60 req/min)
# 取得：https://finnhub.io/register
FINNHUB_API_KEY=

# Alpha Vantage (備用美股數據，免費 5 req/min)
# 取得：https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ---------- 本地路徑（可選） ----------
# TRADINGAGENTS_CACHE_DIR=~/.tradingagents/cache
# TRADINGAGENTS_RESULTS_DIR=~/.tradingagents/results
# TRADINGAGENTS_MEMORY_LOG_PATH=~/.tradingagents/memory/trading_memory.md
